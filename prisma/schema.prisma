datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String   @id @default(uuid())
  googleSubjectId String   @unique
  email           String   @unique
  displayName     String
  role            String   // "Administrator", "Operator", "Viewer", "Auditor"
  status          String   // "Enabled", "Disabled"
  createdDate     String
  lastLogin       String?
  createdBy       String
  permissions     String   // JSON string of permissions
  allowedNetworks String   // JSON string of IPs
  notes           String
  
  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
}

model RolePermission {
  role        String @id // "Administrator", "Operator", "Viewer", "Auditor"
  permissions String // JSON array of permissions
}

model Artifact {
  id                 String   @id @default(uuid())
  name               String
  description        String
  type               String
  mimeType           String
  size               Int
  createdDate        String
  modifiedDate       String
  createdBy          String
  tags               String   // JSON string
  status             String   // "active", "deleted"
  location           String
  previewSupported   Boolean
  downloadSupported  Boolean
  deleteSupported    Boolean
  version            String
  conversationId     String
  workflowId         String
  metadata           String   // JSON string
  lifecycleState     String
  storage            String   // JSON string
  relationships      String   // JSON string
  preview            String   // JSON string
  processing         String   // JSON string
  search             String   // JSON string
  
  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?
}

model Workflow {
  id            String   @id
  name          String
  description   String
  version       String
  status        String   // "active", "draft", "deprecated"
  nodes         String   // JSON string
  capabilities  String   // JSON string
  dependencies  String   // JSON string
  relationships String   // JSON string
  metadata      String   // JSON string
  createdAt     String
  updatedAt     String
  
  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
  
  deletedAt     DateTime?
}

model WorkflowTemplate {
  id          String   @id
  name        String
  description String
  version     String
  nodes       String   // JSON string
  metadata    String   // JSON string

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model WorkflowExecution {
  id              String    @id
  workflowId      String
  workflowVersion String
  workflowName    String
  conversationId  String?
  status          String    // "queued", "running", "succeeded", "failed", "cancelled", etc.
  currentNodeId   String?
  variables       String    // JSON string
  checkpointState String    // JSON string
  createdAt       String
  startedAt       String?
  endedAt         String?
  durationMs      Int?
  error           String?
  steps           String    // JSON string
  logs            String    // JSON string
  artifacts       String    // JSON string
  approvals       String    // JSON string
  retryCount      Int
  maxRetries      Int
  metadata        String    // JSON string
  
  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
  
  deletedAt       DateTime?
}

model WorkflowSchedule {
  id              String   @id
  workflowId      String
  name            String
  type            String   // "cron", "one-time", "recurring", "event-based", "manual", "delayed"
  cronExpression  String?
  intervalSeconds Int?
  runAt           String?
  enabled         Boolean
  lastRun         String?
  nextRun         String?
  retryConfig     String?  // JSON string

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model WorkflowApproval {
  id                String   @id
  executionId       String
  nodeId            String
  workflowId        String
  workflowName      String
  type              String   // "single", "multiple", "quorum"
  approvers         String   // JSON string
  quorumPercentage  Int?
  timeoutSeconds    Int?
  escalationUser    String?
  status            String   // "pending", "approved", "rejected", "timed_out", "delegated"
  decisions         String   // JSON string
  delegatedTo       String?
  createdAt         String
  actionedAt        String?

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model WorkflowHistory {
  id         String   @id
  workflowId String
  changeType String   // "create", "update_definition", "new_version", "deprecate"
  version    String
  userId     String
  userEmail  String
  details    String
  timestamp  String

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model AuditLogEntry {
  id         String   @id
  timestamp  String
  userId     String
  action     String
  category   String   // "authentication" | "authorization" | "configuration" etc.
  details    String
  ipAddress  String

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model AuditEvent {
  id        String   @id @default(uuid())
  timestamp String
  eventType String   // "Login Success", "Login Failure", etc.
  userId    String?
  userEmail String?
  ipAddress String?
  details   String

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model Config {
  id                    String   @id @default("active")
  port                  Int
  rateLimitMax          Int
  rateLimitWindowMs     Int
  sessionTimeoutMinutes Int
  databasesDir          String
  artifactsDir          String
  logsDir               String
  uploadsDir            String
  exportsDir            String
  maintenanceMode       Boolean
  readOnlyMode          Boolean
  maintenanceBanner     String

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model ConfigHistory {
  version   Int      @id
  timestamp String
  changedBy String
  config    String   // JSON string
  notes     String

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model FeatureFlag {
  id          String   @id
  name        String
  category    String
  description String
  enabled     Boolean

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model Secret {
  key            String   @id
  encryptedValue String
  iv             String
  authTag        String
  updatedAt      String

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model SchedulerJob {
  id             String   @id
  name           String
  cronExpression String
  type           String   // 'backup' | 'cleanup' | 'health_check' | 'sync'
  status         String   // 'idle' | 'running' | 'failed' | 'success'
  lastRun        String?
  nextRun        String?
  enabled        Boolean
  message        String?

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model Job {
  id          String   @id
  name        String
  payload     String   // JSON string
  status      String   // "queued", "running", "completed", "failed", etc.
  priority    String   // "critical", "high", "medium", "low"
  progress    Int
  retryPolicy String   // JSON string
  errors      String   // JSON string
  createdAt   String
  startedAt   String?
  completedAt String?
  result      String?  // JSON string

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model SecurityState {
  key   String @id // e.g. "lockout:ip", "ban:ip", etc.
  value String // JSON data
}

model JobCheckpoint {
  id              String   @id @default(uuid())
  jobId           String
  stageName       String
  progress        Int
  checkpointState String   // JSON string
  timestamp       String

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

model Session {
  id         String @id
  userId     String
  role       String
  createdAt  BigInt
  lastActive BigInt

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?
}

// ============================================================================
// Enterprise SaaS Models
// ============================================================================

model Organization {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  displayName   String
  status        String   // "active" | "suspended" | "deleted"
  tier          String   // "free" | "professional" | "business" | "enterprise" | "custom"
  domain        String?
  customDomain  String?
  logoUrl       String?
  primaryRegion String
  settings      String   // JSON string representing OrganizationSettings
  metadata      String   // JSON string representing custom metadata
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
}

model Tenant {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String   @unique
  displayName    String
  status         String   // "provisioning" | "active" | "suspended" | "archived" | "deleted"
  environment    String   // "development" | "staging" | "production" | "testing"
  region         String
  isolationLevel String   // "shared" | "dedicated" | "airgapped"
  tier           String   // "free" | "professional" | "business" | "enterprise" | "custom"
  settings       String   // JSON string representing TenantSettings
  resourceQuotas String   // JSON string representing ResourceQuotas
  metadata       String   // JSON string representing custom metadata
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  suspendedAt    DateTime?
  archivedAt     DateTime?
  deletedAt      DateTime?
}

model Workspace {
  id             String   @id @default(uuid())
  tenantId       String
  organizationId String
  name           String
  slug           String
  description    String
  status         String   // "active" | "archived" | "deleted"
  departmentId   String?
  businessUnitId String?
  projectId      String?
  settings       String   // JSON string representing WorkspaceSettings
  metadata       String   // JSON string representing custom metadata
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model Project {
  id             String   @id @default(uuid())
  tenantId       String
  organizationId String
  workspaceId    String
  name           String
  slug           String
  description    String
  status         String   // "active" | "archived" | "completed" | "deleted"
  settings       String   // JSON string representing ProjectSettings
  goals          String   // JSON string array
  metadata       String   // JSON string representing custom metadata
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model Department {
  id             String   @id @default(uuid())
  tenantId       String
  organizationId String
  name           String
  description    String
  code           String
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BusinessUnit {
  id             String   @id @default(uuid())
  tenantId       String
  organizationId String
  name           String
  description    String
  code           String
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model License {
  id                  String   @id @default(uuid())
  organizationId      String
  tenantId            String
  licenseKey          String   @unique
  type                String   // "trial" | "subscription" | "enterprise" | "offline" | "usage" | "floating" | "node"
  tier                String   // "free" | "professional" | "business" | "enterprise" | "custom"
  status              String   // "active" | "expired" | "suspended" | "revoked" | "pending-activation"
  seats               Int
  nodes               Int
  features            String   // JSON string (array of string feature IDs)
  usageLimits         String   // JSON string (metric name -> limit)
  activatedAt         DateTime?
  expiresAt           DateTime
  renewalDate         DateTime?
  offlineCapable      Boolean
  hardwareFingerprint String?
  metadata            String   // JSON string representing custom metadata
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Subscription {
  id                 String   @id @default(uuid())
  organizationId     String
  tenantId           String
  planId             String
  tier               String   // "free" | "professional" | "business" | "enterprise" | "custom"
  status             String   // "active" | "trialing" | "past-due" | "cancelled" | "suspended" | "expired"
  billingCycle       String   // "monthly" | "annual" | "custom"
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  seats              Int
  additionalSeats    Int
  addOns             String   // JSON string representing array of SubscriptionAddOn
  supportPlan        String   // "community" | "basic" | "standard" | "premium" | "dedicated"
  licenseId          String?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  metadata           String   // JSON string representing custom metadata
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UsageRecord {
  id             String   @id @default(uuid())
  tenantId       String
  organizationId String
  workspaceId    String?
  userId         String?
  category       String   // "ai" | "gpu" | "storage" | "api" | "knowledge" | "marketplace" | "workflow" | "compute"
  metric         String
  quantity       Float
  unit           String
  unitCost       Float
  totalCost      Float
  metadata       String   // JSON string representing custom metadata
  timestamp      DateTime
}

model Invoice {
  id                 String   @id @default(uuid())
  organizationId     String
  tenantId           String
  subscriptionId     String
  invoiceNumber      String   @unique
  status             String   // "draft" | "issued" | "paid" | "past-due" | "void" | "refunded"
  periodStart        DateTime
  periodEnd          DateTime
  lineItems          String   // JSON string representing array of InvoiceLineItem
  subtotalCents      Int
  discountCents      Int
  creditAppliedCents Int
  taxCents           Int
  totalCents         Int
  currency           String
  dueDate            DateTime
  paidAt             DateTime?
  metadata           String   // JSON string representing custom metadata
  
  createdAt          DateTime @default(now())
}

model GovernancePolicy {
  id               String   @id @default(uuid())
  organizationId   String
  tenantId         String?
  name             String
  type             String   // "authentication" | "authorization" | "network" | "data-classification" | etc.
  enabled          Boolean
  configuration    String   // JSON string representing policy configuration
  enforcementLevel String   // "advisory" | "enforced" | "strict"
  createdBy        String
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WhiteLabelConfig {
  id                         String   @id @default(uuid())
  tenantId                   String   @unique
  organizationId             String
  primaryColor               String
  secondaryColor             String
  accentColor                String
  backgroundColor            String
  surfaceColor               String
  textColor                  String
  fontFamily                 String
  headingFontFamily          String
  theme                      String
  customCss                  String?
  customDomain               String?
  customDomainVerified       Boolean
  customDomainCertificateId  String?
  navigationItems            String   // JSON string representing array of NavigationItem
  hideDefaultBranding        Boolean
  emailFromName              String
  emailFromAddress           String?
  emailTemplateOverrides     String   // JSON string representing overrides
  helpCenterUrl              String?
  supportEmail               String?
  termsUrl                   String?
  privacyUrl                 String?
  loginPageTitle             String
  loginPageSubtitle          String
  loginPageBackgroundUrl     String?
  ssoButtonLabel             String
  marketplaceName            String
  marketplaceLogoUrl         String?
  
  updatedAt                  DateTime @updatedAt
}

model MobileDevice {
  id           String    @id @default(uuid())
  name         String
  publicKey    String
  fingerprint  String    @unique
  status       String    // "PENDING", "APPROVED", "REVOKED"
  metadata     String    // JSON string for OS info, model, etc.
  pushToken    String?
  pairingToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  approvedAt   DateTime?
  revokedAt    DateTime?
}

model MobileSession {
  id         String   @id @default(uuid())
  deviceId   String
  userId     String?
  jwtJti     String   @unique
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastActive DateTime @default(now())
  status     String   // "ACTIVE", "REVOKED", "EXPIRED"
}

model MobileRefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  deviceId   String
  userId     String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  replacedBy String?
}

model PairingChallenge {
  token      String   @id
  code       String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
}

model Command {
  id              String    @id @default(uuid())
  type            String    // e.g. "infrastructure:start_service", "ai:load_model", "agent:start", etc.
  status          String    // "QUEUED", "PENDING_APPROVAL", "RUNNING", "COMPLETED", "FAILED", "CANCELLED", "ROLLED_BACK"
  priority        String    // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  payload         String    // JSON string parameters
  riskLevel       String    // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  
  // Security & Authentication
  userId          String?
  userEmail       String?
  deviceId        String?
  origin          String    // "mobile" | "console" | "system"
  signature       String?   // Cryptographic signature from secure enclave
  replayNonce     String?   // UUID nonce
  expiresAt       DateTime? // Expiry timestamp for signature validation

  // Approval Engine State
  approvalType    String    // "AUTO" | "MANUAL" | "MULTI_STAGE" | "EMERGENCY"
  approvalStatus  String    // "PENDING" | "APPROVED" | "REJECTED" | "EXPIRED" | "BYPASSED"
  approvers       String    // JSON array of decisions: [{userId, action, timestamp, signature}]
  approvalTimeout DateTime? // Expiration time for manual approvals

  // Execution & Timing
  scheduledAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  
  // Workers & Queuing
  retryCount      Int       @default(0)
  maxRetries      Int       @default(3)
  nextAttemptAt   DateTime?
  errorMessage    String?
  result          String?   // JSON result payload
  rollbackResult  String?   // JSON rollback outcome

  // Rollback Configuration
  rollbackPayload String?   // JSON arguments needed to undo this command
  rolledBackAt    DateTime?
  rolledBackBy    String?

  @@index([status])
  @@index([scheduledAt])
}

model Conversation {
  id         String    @id @default(uuid())
  title      String
  userId     String?
  deviceId   String?
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String        // "user" | "assistant" | "system"
  content        String
  intent         String?
  entities       String?       // JSON string
  executionPlan  String?       // JSON string
  commands       String?       // JSON string
  createdAt      DateTime      @default(now())
}

model FeedbackTicket {
  id                   String   @id @default(uuid())
  timestamp            DateTime @default(now())
  reportType           String   // "BUG", "FEATURE", "GENERAL"
  userEmail            String
  appVersion           String
  devicePlatform       String   // "web", "android", "ios"
  audioLocation        String   // Path to file on disk
  emailNotificationSent Boolean  @default(false)
}

model Skill {
  id              String   @id
  name            String
  purpose         String
  domain          String   // e.g., "ai_engineering", "security", etc.
  version         String   // e.g., "1.0.0"
  status          String   // "enabled" | "disabled" | "degraded"
  triggers        String   // JSON array of strings
  prerequisites   String   // JSON array of strings
  dependencies    String   // JSON array of strings (dependencies on other skill IDs)
  supportedTools  String   // JSON array of strings
  inputSchema     String   // JSON representation of input schema
  outputSchema    String   // JSON representation of output schema
  confidenceScore Float    // confidence level metric
  executionCost   Float    // estimated execution cost metric
  latencyMs       Int      // average latency in milliseconds
  sandboxPolicy   String   // JSON string of SandboxPolicy
  permissions     String   // JSON array of strings
  metadata        String   // JSON metadata

  // Multi-tenant scaffolding
  organizationId  String?
  tenantId        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
}

model SkillExecution {
  id              String   @id @default(uuid())
  skillId         String
  status          String   // "queued" | "running" | "succeeded" | "failed" | "paused"
  input           String   // JSON string representing input values
  output          String?  // JSON string representing output values
  error           String?
  durationMs      Int?
  cost            Float?
  trace           String   // JSON string representing array of SkillExecutionStep
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  parentId        String?  // parent SkillExecution ID if orchestrated
  workflowId      String?  // associated workflow execution ID if any

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SkillTelemetry {
  id              String   @id @default(uuid())
  skillId         String
  metricName      String   // "latency", "cost", "success", "failure", "sandbox_violation"
  value           Float
  timestamp       DateTime @default(now())
  metadata        String?  // JSON string representing additional metadata
}

model EvaluationScorecard {
  id                     String   @id @default(uuid())
  timestamp              String
  correlationId          String
  traceId                String
  promptId               String
  modelId                String
  correctness            Float
  completeness           Float
  grounding              Float
  confidence             Float
  security               Float
  compliance             Float
  latencyMs              Int
  costUsd                Float
  businessValue          Float
  userObjectiveFulfilled Boolean
  safetyViolation        Boolean
  details                String? // JSON string
}

model UniversalExecution {
  id                String    @id
  executionId       String    @unique
  correlationId     String
  parentExecutionId String?
  childExecutions   String    // JSON array of strings
  status            String
  userContext       String    // JSON string
  workspaceContext  String?   // JSON string
  projectContext    String?   // JSON string
  intent            String    // JSON string
  capability        String    // JSON string
  executionPlan     String?   // JSON string
  workflowReference String?   // JSON string
  priority          String
  createdAt         String
  startedAt         String?
  endedAt           String?
  durationMs        Int?
  error             String?
  steps             String    // JSON string
  artifacts         String    // JSON string
  toolsUsed         String    // JSON string
  retryCount        Int
  maxRetries        Int
  metadata          String    // JSON string
  telemetry         String    // JSON string
  costMetrics       String    // JSON string
  timeline          String    // JSON string
}

model Mission {
  id                String   @id
  name              String
  goals             String   // JSON string array
  constraints       String   // JSON string array
  status            String   // "CREATED" | "PLANNING" | "EXECUTING" | "REFLECTING" | "COMPLETED" | "FAILED"
  history           String   // JSON string array of events
  decisions         String   // JSON string array
  artifacts         String   // JSON string array
  evaluations       String   // JSON string array of MissionEvaluation
  confidence        Float
  lessons           String   // JSON string array
  metrics           String   // JSON string representing MissionMetrics
  createdAt         String
  updatedAt         String
  activeExecutionId String?
  workspaceId       String?
  projectId         String?
}






