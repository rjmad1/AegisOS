# =============================================================================
# AegisOS Platform — Environment Configuration Template
# =============================================================================
# Copy this file to .env.local (development) or .env.production (production).
# NEVER commit .env.local or .env.production to version control.
#
# All values below are PLACEHOLDERS. You MUST replace them before running.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Application
# -----------------------------------------------------------------------------
# Current node execution environment (development | production | test)
NODE_ENV=development

# Server port to bind the application to
PORT=3000

# Base URL of the console application for redirects and links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL of the console when behind a proxy or reverse tunnel
CONSOLE_PUBLIC_URL=http://localhost:3000

# Optional deployment build version string
OPS_BUILD_VERSION=1.0.0

# Optional deployment timestamp or date
OPS_DEPLOYMENT_DATE=2026-07-15

# Optional Git commit hash representing this deploy
OPS_GIT_COMMIT=head

# Whether to enable global maintenance mode (true | false)
OPS_MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# Authentication — OAuth, LDAP & Entra ID
# -----------------------------------------------------------------------------
# Active authentication provider (google | ldap | entra | local)
AUTH_PROVIDER=google

# Google OAuth Client ID. Register at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# LDAP Directory service URL for user credentials verification
LDAP_URL=ldap://127.0.0.1:389

# Microsoft Entra ID Client Application ID
ENTRA_CLIENT_ID=entra_oauth_client_id_dev_secure

# Microsoft Entra ID Client Secret Key
ENTRA_CLIENT_SECRET=entra_oauth_client_secret_dev_secure

# -----------------------------------------------------------------------------
# Session & JWT Security
# -----------------------------------------------------------------------------
# Session authentication key. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_SECRET=CHANGE_ME_generate_a_64_byte_hex_secret

# Encryption key for JWT credentials. Choose a different strong hex string.
OPS_JWT_SECRET=CHANGE_ME_generate_a_different_64_byte_hex_secret

# -----------------------------------------------------------------------------
# Admin Portal Credentials
# -----------------------------------------------------------------------------
# Username required to access the local developer panel
OPS_ADMIN_USERNAME=CHANGE_ME_choose_admin_username

# Password required to access the local developer panel
OPS_ADMIN_PASSWORD=CHANGE_ME_choose_strong_password

# -----------------------------------------------------------------------------
# Session & Rate Limiting
# -----------------------------------------------------------------------------
# Maximum duration of a user session before forcing re-login (in minutes)
OPS_SESSION_TIMEOUT_MINUTES=480

# Maximum number of API requests allowed per window per IP
OPS_RATE_LIMIT_MAX=150

# Time frame window size in milliseconds for the rate limiter
OPS_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# AI Runtime — Local Service Endpoints
# -----------------------------------------------------------------------------
# Ollama local inference endpoint. Default is http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Public Ollama gateway endpoint for client-side queries
NEXT_PUBLIC_OLLAMA_URL=http://127.0.0.1:11434

# LiteLLM router proxy endpoint. Default is http://127.0.0.1:4000
LITELLM_BASE_URL=http://127.0.0.1:4000

# Public LiteLLM gateway endpoint for client-side routing queries
NEXT_PUBLIC_LITELLM_URL=http://127.0.0.1:4000

# Public AegisOS MCP proxy endpoint. Default is http://127.0.0.1:18789
NEXT_PUBLIC_AEGISOS_URL=http://127.0.0.1:18789

# Local backend URL for developer Kanban board integration
KANBAN_BACKEND_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Database Persistence
# -----------------------------------------------------------------------------
# Database Connection string. Use 'file:../databases/dev.db' for SQLite, or 'postgresql://USER:PASSWORD@HOST:5432/DATABASE' for Postgres.
DATABASE_URL="file:../databases/dev.db"

# -----------------------------------------------------------------------------
# Redis Cache Configuration
# -----------------------------------------------------------------------------
# Redis cluster host address
REDIS_HOST=localhost

# Redis cluster TCP port
REDIS_PORT=6379

# Full Redis connection string (e.g. redis://user:password@host:port)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Object Storage & S3 Providers
# -----------------------------------------------------------------------------
# Active storage backend provider (local | s3 | gcs | azure | minio)
OBJECT_STORAGE_PROVIDER=local

# Endpoint URL for MinIO local object storage
MINIO_ENDPOINT=http://127.0.0.1:9000

# AWS S3 Access Key ID
AWS_ACCESS_KEY_ID=your_aws_access_key

# AWS S3 Secret Access Key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS datacenter region code for the S3 bucket
AWS_REGION=us-east-1

# Target AWS S3 bucket name
AWS_S3_BUCKET=your-s3-bucket-name

# Google Cloud Storage bucket name
GCS_BUCKET=your-gcs-bucket-name

# Google Cloud Project ID hosting the GCS bucket
GCP_PROJECT_ID=your-gcp-project-id

# Azure Blob Storage connection string
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string

# Azure Blob storage container name
AZURE_CONTAINER=your-azure-container-name

# -----------------------------------------------------------------------------
# Secrets Provider
# -----------------------------------------------------------------------------
# Provider to retrieve runtime encrypted configurations (local | vault | aws | gcp | azure)
SECRETS_PROVIDER=local

# Hashicorp Vault server base URL
VAULT_ADDR=http://127.0.0.1:8200

# Hashicorp Vault API auth token
VAULT_TOKEN=CHANGE_ME_vault_token

# Mount path inside the Vault secret engine
VAULT_MOUNT_PATH=secret/data/aegisos

# Azure KeyVault instance endpoint URL
AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/

# -----------------------------------------------------------------------------
# Email SMTP Server Alerts
# -----------------------------------------------------------------------------
# Host address of SMTP server for outgoing emails
SMTP_HOST=smtp.gmail.com

# SMTP connection port (e.g. 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Username/email address for SMTP server authentication
SMTP_USER=your-smtp-username@gmail.com

# Password/app-token for SMTP server authentication
SMTP_PASS=your-smtp-password

# Sender 'From' email header field
SMTP_FROM=system-alerts@aegis-os.local

# -----------------------------------------------------------------------------
# Multi-Node mTLS Security
# -----------------------------------------------------------------------------
# Shared cryptographic passphrase for cluster node verification
MTLS_SHARED_SECRET=CHANGE_ME_shared_cluster_secret_key

# Enforce secure mTLS validation between cluster endpoints (true | false)
MULTI_NODE_MTLS_ENFORCED=false

# -----------------------------------------------------------------------------
# Observability & Telemetry
# -----------------------------------------------------------------------------
# OpenTelemetry OTLP Collector grpc/http receiver endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# External Directories (production only)
# -----------------------------------------------------------------------------
# Path to folder containing runtime SQLite or configuration databases
DATABASE_DIR=D:/AI-Operations/runtime/databases

# Path to folder where developer outputs and records are stored
OPS_ARTIFACTS_DIR=D:/AI-Operations/artifacts

# Path to directory where operational backup copies are stored
OPS_BACKUPS_DIR=D:/AI-Operations/backups

# Path to directory where central system logs are outputted
OPS_LOGS_DIR=D:/AI-Operations/logs

# Path to directory where uploaded user files are staged
OPS_UPLOADS_DIR=D:/AI-Operations/uploads

# Path to folder where exported files are stored
OPS_EXPORTS_DIR=D:/AI-Operations/exports

# Direct path to the console runtime json config file
OPS_CONFIG_PATH=D:/AI-Operations/runtime/console_config.json

# Path to the state directory of the AegisOS host
AEGISOS_STATE_DIR=D:/AegisOS

# Path to AegisOS console configuration spec json file
AEGISOS_CONFIG_PATH=D:/AegisOS/Config/aegisos.json

# -----------------------------------------------------------------------------
# Open WebUI Integration
# -----------------------------------------------------------------------------
# Host port to expose Open WebUI. Default is 8090.
HOST_PORT_OPEN_WEBUI=8090

# Security key for session signing. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
WEBUI_SECRET_KEY=CHANGE_ME_generate_a_strong_open_webui_secret_key

