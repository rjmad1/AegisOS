    "firewallMode": "BlockAllOutbound",
    "rateLimitingEnabled": true,
    "encryptionEnabled": true
  },
  "supportLevel": "basic",
  "modelsToPull": [],
  "bundledExtensions": [
    "com.aegisos.ext.logger",
    "com.aegisos.provider.ollama",
    "com.aegisos.ext.translator"
  ]
}
