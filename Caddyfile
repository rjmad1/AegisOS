# AI Operations Console Caddy Configuration
{
	# Global options
	email admin@ai-ops.local
	local_certs # For local development and LAN HTTPS
	skip_install_trust
}

# HTTPS service endpoint on port 8443 (abstracts transport layer, supports LAN, WAN, Custom Domain)
localhost:8443 {
	# Reverse proxy to the local Next.js Operations Console (internal port 3000)
	reverse_proxy localhost:3000 {
		# Preserve client details and support Server-Sent Events (SSE) & WebSockets
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}

	# Enable compression for maximum response throughput
	encode zstd gzip

	# Enforce secure HTTPS response headers (Defense-in-depth)
	header {
		# Anti-Clickjacking protection
		X-Frame-Options "SAMEORIGIN"
		# MIME Sniffing protection
		X-Content-Type-Options "nosniff"
		# Secure Referrer routing
		Referrer-Policy "strict-origin-when-cross-origin"
		# Secure Permissions Policy
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# Content Security Policy (allows inline styling and scripts required by Monaco/Zustand)
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ws: wss:; frame-ancestors 'none'; object-src 'none';"
		# HSTS (Strict Transport Security)
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	# Cache static assets from Next.js build
	@static_assets {
		path /_next/static/*
		path /favicon.ico
	}
	header @static_assets Cache-Control "public, max-age=31536000, immutable"

	# Request Access Logging with rotation
	log {
		output file D:\AI-Operations\logs\caddy_access.log {
			roll_size 10mb
			roll_keep 5
			roll_keep_for 720h
		}
		format json
	}
}
